# Copiez ce fichier en infra/azure/env.sh puis remplissez, et `source infra/azure/env.sh`.
# NE COMMITEZ PAS env.sh (il est ignoré par .gitignore).

# --- Azure ---
export LOCATION="francecentral"
export RG="cal-medianes-rg"
export ACR_NAME="calmedianesacr"          # alphanumérique, unique globalement
export PG_SERVER="cal-medianes-pg"        # unique
export PG_ADMIN_USER="caladmin"
export PG_ADMIN_PASSWORD="CHANGE_ME_strong_password"
export PG_DB="calcom"
export ACA_ENV="cal-env"
export ACA_APP="cal-web"

# --- Application ---
export PUBLIC_URL="https://cal.medianes.org"        # URL publique HTTPS finale
export NEXTAUTH_SECRET="$(openssl rand -base64 32)" # ou fixez une valeur stable
export CALENDSO_ENCRYPTION_KEY="$(openssl rand -base64 24)"  # 32 chars

# --- SMTP (fournisseur externe) ---
# Exemple Resend : host smtp.resend.com, user "resend", password = clé API
export EMAIL_FROM="notifications@medianes.org"
export EMAIL_SERVER_HOST="smtp.resend.com"
export EMAIL_SERVER_PORT="587"
export EMAIL_SERVER_USER="resend"
export EMAIL_SERVER_PASSWORD="re_CHANGE_ME_api_key"
